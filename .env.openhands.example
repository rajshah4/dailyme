# Environment variables for OpenHands Cloud to run the pipeline
# Copy this to .env and fill in your values
# 
# IMPORTANT: Add .env to your repo (commit it) if you want OpenHands Cloud to use it.
# Make sure your repo is private, or use a different method to provide credentials.

# Database connection (required)
DATABASE_URL=postgresql+asyncpg://user:password@ep-xxx.us-east-1.aws.neon.tech/dailyme

# Gmail API credentials (required)
# This is the full token.json content as a JSON string
GMAIL_TOKEN_JSON='{"token": "ya29...", "refresh_token": "1//...", "token_uri": "https://oauth2.googleapis.com/token", "client_id": "xxx.apps.googleusercontent.com", "client_secret": "xxx", "scopes": ["https://www.googleapis.com/auth/gmail.modify"], "universe_domain": "googleapis.com", "expiry": "2024-01-01T00:00:00.000000Z"}'

# LLM configuration (optional, defaults provided)
LLM_MODEL=openhands/claude-sonnet-4-5-20250929
LLM_API_KEY=sk-...  # Your OpenHands API key
LLM_TIMEOUT=120
LLM_NUM_RETRIES=2

# Gmail config (optional)
GMAIL_INBOX_ADDRESS=your-dailyme-inbox@gmail.com
