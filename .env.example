# Database (Neon Postgres)
DATABASE_URL=postgresql+asyncpg://user:password@host/dailyme

# Gmail API
GMAIL_CREDENTIALS_JSON=credentials.json
GMAIL_TOKEN_JSON=token.json
GMAIL_INBOX_ADDRESS=dailyme.inbox@gmail.com

# SendGrid (daily digest)
SENDGRID_API_KEY=SG.xxxxx
DIGEST_TO_EMAIL=you@example.com
DIGEST_FROM_EMAIL=digest@dailyme.app

# App settings
DIGEST_HOUR=8
DIGEST_TIMEZONE=US/Eastern
POLL_INTERVAL_SECONDS=120
